{
  "name": "buffel-simulator-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 4200",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "cy:run": "cypress run",
    "e2e:ci": "start-server-and-test start http://localhost:4200 cy:run"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "luxon": "^3.7.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/mocha": "^10.0.10",
    "@vitest/coverage-v8": "^4.1.9",
    "cypress": "^15.16.0",
    "jsdom": "^27.1.0",
    "start-server-and-test": "^3.0.9",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
